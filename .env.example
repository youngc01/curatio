# =============================================================================
# Stremio AI Addon Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to git - it contains secrets!

# -----------------------------------------------------------------------------
# TMDB API (Required)
# -----------------------------------------------------------------------------
# Get your API key: https://www.themoviedb.org/settings/api
# Free tier: 40 requests per 10 seconds (~240/min)
TMDB_API_KEY=your_tmdb_api_key_here

# -----------------------------------------------------------------------------
# Gemini API (Required)
# -----------------------------------------------------------------------------
# Get your API key: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day
# Paid tier: Enable billing for initial $5 build, then disable
GEMINI_API_KEY=your_gemini_api_key_here

# Set to 'true' for initial $5 tagging job, then set to 'false'
GEMINI_PAID_TIER=false

# Model to use (flash is fastest and cheapest)
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Trakt API (Required)
# -----------------------------------------------------------------------------
# Create OAuth app: https://trakt.tv/oauth/applications/new
# You'll get both Client ID and Client Secret
TRAKT_CLIENT_ID=your_trakt_client_id_here
TRAKT_CLIENT_SECRET=your_trakt_client_secret_here

# Your domain where the addon is hosted
# This MUST match the redirect URI in your Trakt app settings
TRAKT_REDIRECT_URI=https://yourdomain.com/auth/trakt/callback

# -----------------------------------------------------------------------------
# Master Password (Required)
# -----------------------------------------------------------------------------
# This password gates access to your addon
# Share it only with people you want to have access
# Users enter this once, then use Trakt to log in
MASTER_PASSWORD=change_this_to_a_strong_password_123

# -----------------------------------------------------------------------------
# Database (Auto-configured by Docker Compose)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# If using Docker Compose, this is automatically set
DATABASE_URL=postgresql://postgres:password@postgres:5432/stremio_ai

# Alternative for local testing without Docker
# DATABASE_URL=postgresql://localhost:5432/stremio_ai_test

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Your addon's base URL (where it's publicly accessible)
BASE_URL=https://yourdomain.com

# Addon name shown in Stremio
ADDON_NAME=AI Recommendations

# How many movies/shows per catalog
CATALOG_SIZE=100

# How often to refresh universal catalogs (in hours)
UNIVERSAL_CATALOG_REFRESH_HOURS=24

# How often to refresh personalized catalogs (in hours)
PERSONALIZED_CATALOG_REFRESH_HOURS=24

# Number of personalized catalogs per user
PERSONALIZED_CATALOG_COUNT=10

# Number of universal catalogs
UNIVERSAL_CATALOG_COUNT=40

# -----------------------------------------------------------------------------
# Logging & Monitoring
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode (shows detailed errors)
DEBUG=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Requests per minute per user (prevent abuse)
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens (generate a random string)
SECRET_KEY=change_this_to_a_random_secret_key_min_32_chars

# Token expiration in days
TOKEN_EXPIRATION_DAYS=30

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features for testing
ENABLE_PERSONALIZED_CATALOGS=true
ENABLE_UNIVERSAL_CATALOGS=true
ENABLE_TRAKT_SYNC=true

# -----------------------------------------------------------------------------
# Daily Update Scheduler
# -----------------------------------------------------------------------------
# Automatically fetch and tag new releases daily
# Set to 'true' to enable the in-app scheduler (no cron needed)
DAILY_UPDATE_ENABLED=false

# Time to run the daily update (HH:MM in UTC)
# Default: 03:00 (3 AM UTC)
DAILY_UPDATE_TIME=03:00

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------
# Number of workers for Uvicorn
WORKERS=4

# Database connection pool size
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Cache TTL (time to live) in seconds
CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------
# Skip API key validation (for testing)
# NEVER set to true in production!
SKIP_API_VALIDATION=false
